# =============================================================================
# Web (Next.js) — PRODUCTION (Next ưu tiên khi NODE_ENV=production)
# Sao chép:  cp .env.production.example .env.production
# Docker:    docker-compose.prod.yml → env_file: apps/web/.env.production
# Dev local: dùng apps/web/.env (mẫu .env.example) — đồng bộ cách đặt file với API.
#
# Cổng mở trên máy (vd. 3002 khi tránh xung đột với dev :3000) đặt bằng WEB_HOST_PORT trong
# `.env` GỐC repo — không phải file này. NEXTAUTH_URL / NEXT_PUBLIC_SITE_URL phải dùng URL
# public đúng cổng đó (vd. http://localhost:3002).
# =============================================================================
# Cấu trúc giống apps/web/.env.example — chỉ khác giá trị URL / host.
# =============================================================================

# --- Cổng trong container (next start) — phải khớp cổng bên phải trong docker-compose.prod.yml
# (mặc định 3000). Cổng public máy chủ đặt bằng WEB_HOST_PORT trong `.env` gốc repo.
PORT=3000

# --- NextAuth ---
NEXTAUTH_SECRET="change-me-minimum-32-chars-production!!"
NEXTAUTH_URL="https://yourdomain.com"

# --- API (public = trình duyệt; internal = server Next trong Docker) ---
NEXT_PUBLIC_API_URL="https://api.yourdomain.com"
INTERNAL_API_URL="http://api:4000"

# --- Hiển thị & SEO ---
NEXT_PUBLIC_APP_NAME="Swantech chi tiêu"
# URL public https (og:image, canonical) — trùng NEXT_PUBLIC_SITE_URL khi `docker compose build web` (.env gốc repo)
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# --- MinIO & next/image (next.config — cần khớp lúc `docker compose build web`) ---
# Đặt URL đầy đủ cùng host:port mà trình duyệt dùng để tải ảnh (trùng MINIO_PUBLIC_URL bên API nếu có).
# Ví dụ IP: http://203.0.113.10:9000  |  domain: https://files.yourdomain.com
MINIO_ENDPOINT="https://files.yourdomain.com"
# MINIO_PORT=9000
# MINIO_USE_SSL=false
