# =============================================================================
# File `.env` GỐC REPO — chỉ dùng cho Docker Compose (file docker-compose.prod.yml)
# =============================================================================
# Compose đọc ĐÚNG file tên `.env` ở thư mục này để thay ${BIẾN} trong YAML.
# Compose KHÔNG tự đọc apps/api/.env.production hay apps/web/.env.production để thay
# biến trong file compose — nên cổng public (API_HOST_PORT, WEB_HOST_PORT) và một số
# mật khẩu dịch vụ (postgres/redis/minio container) đặt Ở ĐÂY.
#
# Còn apps/api/.env.production & apps/web/.env.production = biến NẠP VÀO CONTAINER
# (runtime Node: DATABASE_URL, NEXTAUTH, PORT trong container, …).
#
# Sao chép: cp .env.example .env  rồi đổi mật khẩu / URL / cổng.
# =============================================================================

# --- PostgreSQL (container `postgres`) — user + password DB trong Docker ---
POSTGRES_DB=expense_splitter
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password
# Map ra máy chủ (docker-compose.prod.yml): host:5432 → container 5432 — đổi nếu đã có Postgres local
# POSTGRES_HOST_PORT=5432

# --- Redis (container `redis`) — mật khẩu Redis; phải khớp REDIS_URL trong apps/api/.env.production ---
REDIS_PASSWORD=change-me-redis-password

# --- MinIO (container `minio`) — user + password root MinIO (giống tên image chính thức) ---
# Trong apps/api/.env.production dùng cùng cặp MINIO_ROOT_USER / MINIO_ROOT_PASSWORD (SDK đọc).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-secret

# --- Build image Web (docker compose build web) ---
# URL site public https — dùng cho og:image / preview Facebook; phải trùng NEXT_PUBLIC_SITE_URL trong apps/web/.env.production
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
# URL API mà trình duyệt gọi (public). Ví dụ https://api.example.com
NEXT_PUBLIC_API_URL=https://api.example.com
# Build `web`: host:port ảnh MinIO cho next/image (trùng MINIO_PUBLIC_URL / URL public tới MinIO)
# MINIO_ENDPOINT=https://files.example.com
# MINIO_PORT=
# MINIO_USE_SSL=false

# --- Cổng public trên máy chủ (map host → cổng trong container; bên phải cố định trong compose) ---
# WEB_HOST_PORT = cổng bạn mở trên máy (vd. 3002). KHÔNG đặt trong apps/web/.env.production —
# Compose chỉ đọc biến ở file `.env` này. Nếu lỗi "port 3000 already allocated" (dev Next
# đang chạy 3000), đặt WEB_HOST_PORT=3002 rồi sửa NEXTAUTH_URL / NEXT_PUBLIC_SITE_URL trong
# apps/web/.env.production cho khớp (vd. http://localhost:3002).
# API_HOST_PORT=4000
WEB_HOST_PORT=3002
