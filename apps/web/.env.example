# =============================================================================
# Web (Next.js) — DEV (cùng bộ biến với .env.production.example, khác giá trị local)
#
# Cách làm giống API:  cp .env.example .env
#
# Dev: chỉ cần file `.env` (sao chép từ file này). Next vẫn đọc thêm
# `.env.development` / `.env.development.local` nếu có — không bắt buộc.
#
# Production: NODE_ENV=production → dùng .env.production (Docker: env_file trong compose).
# Mẫu: .env.production.example → .env.production
#
# Cổng dev: đặt PORT (Next đọc khi chạy next dev). Đổi NEXTAUTH_URL / NEXT_PUBLIC_SITE_URL
# cho khớp (vd. PORT=3001 → http://localhost:3001).
# =============================================================================

# --- Cổng local (next dev) ---
PORT=3000

# --- NextAuth ---
NEXTAUTH_SECRET=change-me-dev-secret-at-least-32-chars-long!!
NEXTAUTH_URL=http://localhost:3000

# --- API ---
NEXT_PUBLIC_API_URL=http://localhost:4000
# Nếu chạy Web trong Docker cùng compose với api: đổi thành http://api:4000
INTERNAL_API_URL=http://127.0.0.1:4000

# --- Hiển thị & SEO ---
NEXT_PUBLIC_APP_NAME=Quản lý chi tiêu
# Số phiên bản (badge header): lấy từ apps/web/package.json → version — không dùng biến env
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- MinIO & next/image (next.config — build lúc next build / Docker build) ---
# URL đầy đủ (khuyến nghị): http://127.0.0.1:9000 — hoặc chỉ hostname rồi đặt MINIO_PORT
MINIO_ENDPOINT=http://localhost:9000
# MINIO_PORT=9000
# MINIO_USE_SSL=false

# Kiểm tra API: curl http://localhost:4000/health
