# Sao chép thành .env hoặc .env.local (API đọc cả hai; .env.local ghi đè .env).
PORT=4000
# Mặc định 0.0.0.0 — lắng nghe mọi interface (dev). Chỉ đặt 127.0.0.1 nếu muốn giới hạn local.
# API_HOST=0.0.0.0
NODE_ENV=development

# Docker: set to 1 to skip `prisma migrate deploy` in entrypoint (not recommended)
# SKIP_DB_MIGRATE=

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/expense_splitter"

JWT_SECRET="change-me-minimum-32-chars!!"
JWT_EXPIRES_IN="7d"

# SDK MinIO: URL đầy đủ (http://host:9000) hoặc chỉ host + MINIO_PORT bên dưới
MINIO_ENDPOINT="http://localhost:9000"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
# URL gắn object cho trình duyệt (khác host nội bộ Docker). Không set thì suy ra từ MINIO_ENDPOINT nếu là URL
# MINIO_PUBLIC_URL="http://127.0.0.1:9000"
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin"
MINIO_BUCKET="expense-splitter"

REDIS_URL="redis://localhost:6379"

RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
CRON_SECRET="change-me-cron-secret"

# Phải khớp origin trình duyệt (CORS HTTP + Socket.IO handshake)
WEB_URL="http://localhost:3000"
