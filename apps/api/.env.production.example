PORT=4000
NODE_ENV=production
# YOUR_PASSWORD = cùng POSTGRES_PASSWORD trong .env gốc (Compose)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@postgres:5432/expense_splitter"
JWT_SECRET="change-me-minimum-32-chars-production!!"
JWT_EXPIRES_IN="7d"
# Nội bộ Docker: host `minio` + port — hoặc một dòng URL đầy đủ `http://minio:9000`
MINIO_ENDPOINT="http://minio:9000"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
# URL ảnh mà trình duyệt mở được (public). Bắt buộc nếu API dùng host nội bộ nhưng user truy cập qua domain/IP khác
# MINIO_PUBLIC_URL="https://files.yourdomain.com"
# Cùng cặp user/mật khẩu với MINIO_ROOT_USER / MINIO_ROOT_PASSWORD trong .env gốc & container MinIO
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin"
MINIO_BUCKET="expense-splitter"
REDIS_URL="redis://:YOUR_REDIS_PASSWORD@redis:6379"
RESEND_API_KEY="re_..."
CRON_SECRET="change-me-cron-secret"
WEB_URL="https://money.dovancuongadhp.top,http://localhost:3000"
